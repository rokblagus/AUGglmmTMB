family = binomial(link=link_fun),control=glmmTMBControl(optCtrl=list(iter.max=inter_iter,eval.max=inter_iter),profile = FALSE,collect = FALSE), se = FALSE, verbose = FALSE, doFit = TRUE, REML = FALSE)
}
} else {
