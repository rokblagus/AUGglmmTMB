library(readxl)
dd<-read_excel("C:\\Users\\rblagus\\MF Uni LJ Dropbox\\Rok Blagus\\ARRS_project_proposal_2023\\2026_clinical\\data\\data.xlsx")
names(dd)
dd<-dd[,-64]
dd$ID<-1:nrow(dd)
library(tidyr)
library(dplyr)
dd_long <- dd %>%
pivot_longer(
cols = c(
"Rankin at discharge",
"Rankin at 6 months after admission",
"Rankin at 12 months after admission"
),
names_to = "time",
values_to = "Rankin"
) %>%
mutate(
time = recode(time,
"Rankin at discharge" = "discharge",
"Rankin at 6 months after admission" = "6 months",
"Rankin at 12 months after admission" = "12 months"
)
)
dd_long$Y<-ifelse(dd_long$Rankin<2,0,1)
library(glmmTMB)
var_list<-c("ID","Y","time","Sex F/M","Age","Immunocompromised (1=yes, 0=no)","Charlson","Duration of hospital stay in days (ID+Nevro)","CSF-Lkci (x10*6/L)","EM in the past 4 weeks or now (1=yes, 0=no)",
"Tick bite (1=yes 0=no)","Severity score at admission (glavobol+bruhanje+mgt znaki+vročina+tremor+retenca urina+kvalit zavest+krči+somnolenca+stupor/koma+other focal neuro signs)")
nm_var_list<-c("Sex","Age","Immunocompromised","Charlson","Duration","CSF","EM",
"Tick","Severity","ID","time","Y")
dd_long_model<-dd_long[,names(dd_long)%in%var_list]
dd_long_model<-na.omit(dd_long_model)
names(dd_long_model)<-nm_var_list
dd_long_model$time<-factor(dd_long_model$time,levels=c("discharge","6 months","12 months"))
X<-model.matrix(Y~Sex*time+Age*time+Immunocompromised*time+Charlson*time+Duration*time+CSF*time+EM*time+Severity*time,data=dd_long_model)
#Z<-model.matrix(Y~time,data=dd_long_model)
Z<-model.matrix(Y~1,data=dd_long_model)
grouping<-dd_long_model$ID
xdf<-list(Y=dd_long_model$Y,X=X,Z=Z,grouping=grouping)
#xdf$M<-rep(1,length(xdf$Y))
#xdf$W<-rep(1,length(xdf$Y))
fitr2c<-mpl_fitter(xdf,mv_multiplier(xdf),nu=list(1),psi=list(diag(1,1,1)),fit_pGLM = TRUE,maxiter = 1,save_coef = TRUE)
fitr2c<-mpl_fitter(xdf,mv_multiplier(xdf),nu=list(1),psi=list(diag(1,1,1)),fit_pGLM = TRUE,maxiter = 1,save_coef = TRUE,link_fun = "probit")
fitr2c
fitr2c$fit$modelInfo
