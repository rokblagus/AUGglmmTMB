setwd("D:/Mixed_separation_fixed_oct_25/github/binomial_mixed_nonboundary/real_data")
dd<-read.table("dataBirds.txt",header=T,dec=",",sep="\t",fill=TRUE)
X <- model.matrix(parasites~migration+food, dd)
Z<-model.matrix(parasites~migration, dd)
Z1<-model.matrix(parasites~1, dd)
xdf22<-list(Y=dd$parasites,X=X,Z=list(Z,Z1),grouping=list(as.numeric(as.factor(dd$Phylogenetic.Tomi)),as.numeric(as.factor(dd$species))),M=rep(1,nrow(X)),W=rep(1,nrow(X)))
mv_multiplier(xdf22)
psi_opt<-get_psi(xdf22,cfe=mv_multiplier(xdf22),nu=list(3),fit_pGLM=TRUE,maxiter=1,tol=1e-6,link_fun="logit",save_coef=FALSE,inter_iter=1e3)
